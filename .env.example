# Copier vers .env.local et remplir (jamais committer .env.local)
#
# Dev — page Technicien (carrousel) : avec Firebase configuré et `npm run dev`, Auth anonyme
# active les missions démo assignées au profil « MANSOUR » (voir bandeau profil en haut à droite).

# En développement uniquement : désactive la prévisualisation UI sans Firebase (`npm run dev`).
# NEXT_PUBLIC_DISABLE_DEV_UI_PREVIEW=true

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

OPENAI_API_KEY=

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Mode dev (prévisualisation) : Firebase Console → Authentication → Sign-in method → activer « Anonyme »
# pour que les écritures Firestore (ex. envoi d’une demande d’intervention) fonctionnent sans login téléphone.
# Cloud Messaging — Web Push : coller la « Key pair » (clé publique) depuis Firebase Console
# → Paramètres du projet → Cloud Messaging → Certificats Web Push → Couple de clés.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# FCM en local : sans ceci, `npm run dev` ne registre pas le service worker → pas de jeton push.
# Utiliser ENABLE_PWA_IN_DEV=true ou le script npm run dev:pwa.
# ENABLE_PWA_IN_DEV=true

# URL publique de l’app (notifications lien dans Cloud Functions — défaut localhost sinon)
PUBLIC_APP_URL=
NEXT_PUBLIC_CLIENT_PORTAL_DEFAULT_COMPANY_ID=
NEXT_PUBLIC_CLIENT_PORTAL_LOGO_URL=

RESEND_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
