rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /** Photos + signature de fin d’intervention — utilisateurs authentifiés uniquement. */
    match /interventions/{interventionId}/completion/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/jpeg')
          || request.resource.contentType.matches('image/png')
        );
    }

    /** Audio (message vocal du client) - utilisateurs authentifiés uniquement. */
    match /interventions/{interventionId}/{audioFile} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && audioFile.matches('audio\\.(webm|mp4)');
    }

    // Extensions : WebM, MP4/M4A (Safari), OGG, WAV — cf. extFromBlob dans clientAudioUpload.ts
    match /interventions_audio/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 15 * 1024 * 1024
        && fileName.matches('.*\\.(webm|mp4|m4a|ogg|wav)');
    }

    /** Factures PDF (écriture Admin SDK / Functions uniquement). */
    match /invoices/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    /**
     * Chat IVANA (portail / inbox) — images liées à `portal_ivana_chat_messages.imageUrls`.
     * Chemin : companyId / uid auteur / fichier.
     */
    match /portal_ivana_chat/{companyId}/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && (
          companyId == 'demo-local-company'
          || firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)/company_memberships/$(companyId))
          || (
            firestore.exists(/databases/(default)/documents/client_portal_profiles/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/client_portal_profiles/$(request.auth.uid)).data.companyId == companyId
          )
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
